{
  "model_class": "StegDetector",
  "backbone": "efficientnet_b0",
  "feature_dim": 512,
  "hidden_dim": 256,
  "num_classes": 2,
  "dropout_rate": 0.5,
  "patch_size": 64,
  "num_patches": 30,
  "input_channels": 3,
  "input_range": "[0, 1] float32",
  "srm_inside_model": true,
  "image_format": "lossless PNG only (JPEG will fail \u2014 JPEG noise masks LSB signal)",
  "grayscale_to_3ch": "replicate: stack([L,L,L], axis=-1)",
  "embedding_type": "LSB replacement",
  "payload_rate_bpp": 0.4,
  "best_epoch": 20,
  "best_auc": 0.999998,
  "checkpoint_file": "best_model.pth",
  "phase1_epochs": 10,
  "lr_phase1": 0.001,
  "lr_phase2": 0.0001,
  "label_smoothing": 0.05,
  "weight_decay": 0.0001,
  "early_stopping": "patience=5, min_delta=0.001"
}